# ----------------------------------------------------------------------
# BCSAAS Mono Service – Minimal Production‑Ready PHP Docker Image
# ----------------------------------------------------------------------
# No framework dependencies, no Composer, no process manager.
# Uses PHP built‑in server with the project root as front controller.
# ----------------------------------------------------------------------

FROM php:8.3-cli-alpine

# ----------------------------------------------------------------------
# Install system dependencies
# ----------------------------------------------------------------------
RUN apk add --no-cache \
    bash \
    curl \
    git \
    icu-dev \
    oniguruma-dev \
    libzip-dev \
    mariadb-client

# ----------------------------------------------------------------------
# Enable required PHP extensions
# ----------------------------------------------------------------------
RUN docker-php-ext-install \
    pdo \
    pdo_mysql \
    intl \
    mbstring \
    zip

# ----------------------------------------------------------------------
# Set working directory
# ----------------------------------------------------------------------
WORKDIR /app

# ----------------------------------------------------------------------
# Copy application files
# ----------------------------------------------------------------------
COPY . /app

# ----------------------------------------------------------------------
# Ensure storage directory is writable
# ----------------------------------------------------------------------
RUN mkdir -p storage \
    && chmod -R 775 storage

# ----------------------------------------------------------------------
# Expose application port
# ----------------------------------------------------------------------
EXPOSE 9999

# ----------------------------------------------------------------------
# Default environment values
# ----------------------------------------------------------------------
ENV APP_ENV=development \
    APP_DEBUG=true \
    APP_BASE_PATH= \
    APP_BASE_URL=http://localhost:9999

# ----------------------------------------------------------------------
# Start built‑in PHP server
# ----------------------------------------------------------------------
# Front controller is index.php at project root
# ----------------------------------------------------------------------
CMD ["php", "-S", "0.0.0.0:9999", "index.php"]
